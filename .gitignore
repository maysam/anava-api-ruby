/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep

/.bundle
/vendor/bundle
.env

# Ignore key files for decrypting credentials and more.
/config/*.key

# SQLite test database (see db/schema.rb)
/db/*.sqlite3

# Uploaded WAV audio files (see app/services/audio_file_storage.rb)
/storage/*
!/storage/.keep

